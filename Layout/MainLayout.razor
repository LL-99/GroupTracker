@inherits LayoutComponentBase
@using Newtonsoft.Json
@inject GroupTrackerStorageService StorageService
@inject IJSRuntime JSRuntime
<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="tracker-layout">
    <MudAppBar Elevation="0" Class="tracker-appbar">
        <MudText Typo="Typo.h6">Group Tracker</MudText>
        <MudSpacer />
        <MudMenu Color="Color.Inherit"
                 Dense="true"
                 Class="tracker-options-menu">
            <ActivatorContent Context="menu">
                <MudIconButton Icon="@Icons.Material.Filled.MoreVert"
                               Size="Size.Medium"
                               Color="Color.Inherit"
                               Class="tracker-options-button"
                               OnClick="@menu.ToggleAsync" />
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem OnClick="@ExportStateAsync">Export Data</MudMenuItem>
                <MudMenuItem OnClick="@ImportStateAsync">Import Data</MudMenuItem>
                <MudMenuItem OnClick="@ConfirmResetScoresAsync">Reset Scores</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudMainContent Class="tracker-main">
        <MudContainer MaxWidth="MaxWidth.False" Class="tracker-shell">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Background = "#08111f",
            Surface = "#101d31",
            AppbarBackground = "#0d1728",
            DrawerBackground = "#0d1728",
            TextPrimary = "#f4f7fb",
            TextSecondary = "#9db0c8",
            Primary = "#64b5f6",
            Secondary = "#ffcc80",
            Warning = "#f6c453"
        }
    };

    private async Task ConfirmResetScoresAsync()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            "Reset all group scores to 0? This cannot be undone.");

        if (confirmed)
        {
            await StorageService.ResetAllScoresAsync();
        }
    }

    private async Task ExportStateAsync()
    {
        var payload = await StorageService.ExportStateAsync();
        await JSRuntime.InvokeVoidAsync(
            "groupTrackerFiles.downloadJson",
            "group_tracker.json",
            payload);
    }

    private async Task ImportStateAsync()
    {
        var payload = await JSRuntime.InvokeAsync<string?>("groupTrackerFiles.pickJsonFile");
        if (string.IsNullOrWhiteSpace(payload))
        {
            return;
        }

        try
        {
            var imported = await StorageService.ImportStateAsync(payload);
            if (!imported)
            {
                await JSRuntime.InvokeVoidAsync("alert", "The selected file does not contain valid group tracker data.");
            }
        }
        catch (JsonException)
        {
            await JSRuntime.InvokeVoidAsync("alert", "The selected file is not valid JSON.");
        }
    }
}
