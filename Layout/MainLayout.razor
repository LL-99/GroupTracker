@inherits LayoutComponentBase
<MudThemeProvider IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="ToggleDrawer">
            Menu
        </MudButton>
        <MudText Typo="Typo.h6">GroupTracker</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   Href="https://learn.microsoft.com/aspnet/core/"
                   Target="_blank">
            About
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
