@inherits LayoutComponentBase
<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="tracker-appbar">
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="ToggleDrawer">
            Menu
        </MudButton>
        <MudText Typo="Typo.h6">Group Tracker</MudText>
        <MudSpacer />
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">Live Scores</MudChip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Responsive" Class="tracker-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="tracker-shell">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
