@inherits LayoutComponentBase
<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="tracker-appbar">
        <MudText Typo="Typo.h6">Group Tracker</MudText>
        <MudSpacer />
        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">Live Scores</MudChip>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="tracker-shell">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
