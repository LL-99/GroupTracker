@page "/counter"

<PageTitle>Counter</PageTitle>

<MudPaper Outlined="true" Class="pa-6">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h3">Counter</MudText>
        <MudText Typo="Typo.body1" Role="status">Current count: @currentCount</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="IncrementCount">
            Click me
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
