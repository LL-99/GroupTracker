@page "/"
@inject GroupTrackerStorageService StorageService

<PageTitle>Group Tracker</PageTitle>

@if (topGroups.Count == 0)
{
	<MudPaper Class="empty-state pa-8">
		<MudText Typo="Typo.h4">No groups available</MudText>
		<MudText Typo="Typo.body1">Add groups to the stored tracker state to populate the podium.</MudText>
	</MudPaper>
}
else
{
	<div style="height:10vh;" />
	<section class="podium-grid">
		@foreach (var group in GetPodiumSlots())
		{
			<MudPaper Class="@GetPodiumCardClass(group.Place)">
				<MudText Typo="Typo.overline" Class="podium-place">@GetPlaceLabel(group.Place)</MudText>
				<MudText Typo="Typo.h4" Class="podium-group-name">@group.Group.Name</MudText>
				<MudText Typo="Typo.h3" Class="podium-score">@group.Group.TotalScore pts</MudText>
				<MudChipSet T="string" AllClosable="false" Class="player-chip-list">
					@foreach (var player in group.Group.PlayerNames)
					{
						<MudChip T="string" Class="player-chip">@player</MudChip>
					}
				</MudChipSet>
				<div class="score-actions">
					@foreach (var delta in scoreButtons)
					{
						<MudButton Variant="Variant.Filled"
								   Class="score-button"
								   OnClick="@(() => AdjustScoreAsync(group.Group.Id, delta))">
							@FormatDelta(delta)
						</MudButton>
					}
				</div>
			</MudPaper>
		}
	</section>
}

@code {
	private readonly int[] scoreButtons = [-5, -1, 1, 5];
	private List<GroupEntry> topGroups = [];

	protected override async Task OnInitializedAsync()
	{
		await LoadGroupsAsync();
	}

	private async Task AdjustScoreAsync(Guid groupId, int delta)
	{
		await StorageService.UpdateScoreAsync(groupId, delta);
		await LoadGroupsAsync();
	}

	private async Task LoadGroupsAsync()
	{
		var state = await StorageService.GetStateAsync();
		topGroups = state.Groups
			.OrderByDescending(group => group.TotalScore)
			.ThenBy(group => group.Name)
			.Take(3)
			.ToList();
	}

	private List<PodiumSlot> GetPodiumSlots()
	{
		var slots = topGroups
			.Select((entry, index) => new PodiumSlot(entry, index + 1))
			.ToList();

		return slots
			.OrderBy(slot => slot.Place switch
			{
				2 => 0,
				1 => 1,
				3 => 2,
				_ => slot.Place
			})
			.ToList();
	}

	private static string GetPlaceLabel(int place) => place switch
	{
		1 => "1st Place",
		2 => "2nd Place",
		3 => "3rd Place",
		_ => $"{place}th Place"
	};

	private static string GetPodiumCardClass(int place) => place switch
	{
		1 => "podium-card podium-gold podium-first",
		2 => "podium-card podium-silver podium-second",
		3 => "podium-card podium-bronze podium-third",
		_ => "podium-card"
	};

	private static string FormatDelta(int delta) => delta > 0 ? $"+{delta}" : delta.ToString();

	private sealed record PodiumSlot(GroupEntry Group, int Place);
}
