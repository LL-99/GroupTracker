@page "/"
@inject GroupTrackerStorageService StorageService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Group Tracker</PageTitle>

@if (groups.Count == 0)
{
	<MudPaper Class="empty-state pa-8">
		<MudText Typo="Typo.h4">No groups available</MudText>
		<MudText Typo="Typo.body1">Add groups to the stored tracker state to populate the podium.</MudText>
	</MudPaper>
}
else
{
	<div style="height:10vh;" />
	<section class="podium-grid">
		@foreach (var group in GetPodiumSlots())
		{
			<MudPaper Class="@GetPodiumCardClass(group.Rank)">
				<div class="podium-card-header">
					<MudText Typo="Typo.overline" Class="podium-place">@GetPlaceLabel(group.Rank)</MudText>
					<div class="podium-card-header-actions">
						@if (editingGroupId == group.Group.Id)
						{
							<MudIconButton Icon="@Icons.Material.Filled.Check"
										   Size="Size.Small"
										   Color="Color.Inherit"
										   Class="podium-edit-button"
										   OnClick="@SaveGroupEditsAsync" />
							<MudIconButton Icon="@Icons.Material.Filled.Close"
										   Size="Size.Small"
										   Color="Color.Inherit"
										   Class="podium-edit-button"
										   OnClick="@CancelEdit" />
						}
						else
						{
							<MudIconButton Icon="@Icons.Material.Filled.Edit"
										   Size="Size.Small"
										   Color="Color.Inherit"
										   Class="podium-edit-button"
										   OnClick="@(() => StartEdit(group.Group))" />
						}
					</div>
				</div>
				@if (editingGroupId == group.Group.Id)
				{
					<MudTextField T="string"
								  Value="@editGroupName"
								  ValueChanged="@OnEditGroupNameChanged"
								  Variant="Variant.Outlined"
								  Margin="Margin.Dense"
								  Class="podium-inline-input"
								  Placeholder="Group name" />
				}
				else
				{
					<MudText Typo="Typo.h4" Class="podium-group-name">@group.Group.Name</MudText>
				}
				<MudText Typo="Typo.h3" Class="podium-score">@group.Group.TotalScore pts</MudText>
				@if (editingGroupId == group.Group.Id)
				{
					<MudTextField T="string"
								  Value="@editGroupMembers"
								  ValueChanged="@OnEditGroupMembersChanged"
								  Variant="Variant.Outlined"
								  Margin="Margin.Dense"
								  Class="podium-inline-input"
								  Placeholder="Members, comma, separated" />
				}
				else
				{
					<MudChipSet T="string" AllClosable="false" Class="player-chip-list">
						@foreach (var player in group.Group.PlayerNames)
						{
							<MudChip T="string" Class="player-chip">@player</MudChip>
						}
					</MudChipSet>
				}
				<div class="score-panel">
					<MudText Typo="Typo.caption" Class="score-panel-label">Adjust score</MudText>
					<div class="score-actions">
						@foreach (var delta in scoreButtons)
						{
							<MudButton Variant="Variant.Filled"
									   Class="@GetScoreButtonClass(delta)"
									   OnClick="@(() => AdjustScoreAsync(group.Group.Id, delta))">
								@FormatDelta(delta)
							</MudButton>
						}
					</div>
				</div>
			</MudPaper>
		}
	</section>
}

<MudPaper Class="group-count-control" Elevation="6">
	<MudText Typo="Typo.caption" Class="group-count-label">Groups</MudText>
	<div class="group-count-actions">
		<MudIconButton Icon="@Icons.Material.Filled.Remove"
					   Size="Size.Small"
					   Disabled="@(groups.Count <= 1)"
					   Class="group-count-button"
					   OnClick="@RemoveGroupAsync" />
		<MudText Typo="Typo.subtitle2" Class="group-count-value">@groups.Count</MudText>
		<MudIconButton Icon="@Icons.Material.Filled.Add"
					   Size="Size.Small"
					   Class="group-count-button"
					   OnClick="@AddGroupAsync" />
	</div>
</MudPaper>

@code {
	private readonly int[] scoreButtons = [-1, 1, -5, 5];
	private List<GroupEntry> groups = [];
	private Guid? editingGroupId;
	private string editGroupName = string.Empty;
	private string editGroupMembers = string.Empty;

	protected override async Task OnInitializedAsync()
	{
		await LoadGroupsAsync();
		StorageService.StateChanged += OnStorageStateChanged;
	}

	private void OnStorageStateChanged()
	{
		_ = InvokeAsync(async () =>
		{
			await LoadGroupsAsync();
			StateHasChanged();
		});
	}

	private async Task AdjustScoreAsync(Guid groupId, int delta)
	{
		await StorageService.UpdateScoreAsync(groupId, delta);
		await LoadGroupsAsync();
	}

	private async Task AddGroupAsync()
	{
		await StorageService.AddGroupAsync();
		await LoadGroupsAsync();
	}

	private async Task RemoveGroupAsync()
	{
		if (groups.Count <= 1)
		{
			return;
		}

		var groupToRemove = groups[^1];
		if (groupToRemove.TotalScore != 0)
		{
			var confirmed = await JSRuntime.InvokeAsync<bool>(
				"confirm",
				$"Remove {groupToRemove.Name}? Its score is {groupToRemove.TotalScore} and this cannot be undone.");

			if (!confirmed)
			{
				return;
			}
		}

		await StorageService.RemoveGroupAsync(groupToRemove.Id);
		await LoadGroupsAsync();
	}

	private void StartEdit(GroupEntry group)
	{
		editingGroupId = group.Id;
		editGroupName = group.Name;
		editGroupMembers = string.Join(", ", group.PlayerNames);
	}

	private void CancelEdit()
	{
		editingGroupId = null;
		editGroupName = string.Empty;
		editGroupMembers = string.Empty;
	}

	private async Task SaveGroupEditsAsync()
	{
		if (editingGroupId is not Guid groupId)
		{
			return;
		}

		var trimmedName = editGroupName.Trim();
		if (string.IsNullOrWhiteSpace(trimmedName))
		{
			return;
		}

		var playerNames = editGroupMembers
			.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
			.ToList();

		await StorageService.UpdateGroupAsync(groupId, trimmedName, playerNames);
		await LoadGroupsAsync();
		CancelEdit();
	}

	private void OnEditGroupNameChanged(string value)
	{
		editGroupName = value;
	}

	private void OnEditGroupMembersChanged(string value)
	{
		editGroupMembers = value;
	}

	private async Task LoadGroupsAsync()
	{
		var state = await StorageService.GetStateAsync();
		groups = state.Groups
			.OrderByDescending(group => group.TotalScore)
			.ThenBy(group => group.Name)
			.ToList();

		if (editingGroupId is Guid groupId && groups.All(group => group.Id != groupId))
		{
			CancelEdit();
		}
	}

	private List<PodiumSlot> GetPodiumSlots()
	{
		var slots = new List<PodiumSlot>(groups.Count);
		var currentRank = 0;
		int? previousScore = null;

		foreach (var entry in groups)
		{
			if (previousScore != entry.TotalScore)
			{
				currentRank++;
				previousScore = entry.TotalScore;
			}

			slots.Add(new PodiumSlot(entry, currentRank));
		}

		var firstPlaceSlots = slots.Where(slot => slot.Rank == 1).ToList();
		if (firstPlaceSlots.Count != 1)
		{
			return slots;
		}

		var leader = firstPlaceSlots[0];
		var others = slots.Where(slot => slot != leader).ToList();

		return
		[
			.. others.Take(1),
			leader,
			.. others.Skip(1)
		];
	}

	private static string GetPlaceLabel(int place) => place switch
	{
		1 => "1st Place",
		2 => "2nd Place",
		3 => "3rd Place",
		_ => $"{place}th Place"
	};

	private static string GetPodiumCardClass(int place) => place switch
	{
		1 => "podium-card podium-gold podium-first",
		2 => "podium-card podium-silver podium-second",
		3 => "podium-card podium-bronze podium-third",
		_ => "podium-card"
	};

	private static string GetScoreButtonClass(int delta) => delta switch
	{
		< 0 => "score-button score-button-negative",
		> 0 => "score-button score-button-positive",
		_ => "score-button"
	};

	private static string FormatDelta(int delta) => delta > 0 ? $"+{delta}" : delta.ToString();

	private sealed record PodiumSlot(GroupEntry Group, int Rank);

	public void Dispose()
	{
		StorageService.StateChanged -= OnStorageStateChanged;
	}
}
